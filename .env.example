KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MODEL_VERSION=v1

RAW_LOGS_TOPIC=raw_logs
AGGREGATED_EVENTS_TOPIC=aggregated_events
ANOMALIES_TOPIC=anomalies
